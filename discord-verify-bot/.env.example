# Discord Developer Portal → Bot → Token
DISCORD_TOKEN=你的BotToken

# Developer Portal → General Information → Application ID
DISCORD_CLIENT_ID=你的ClientID

# 服务器 ID（开发者模式复制）
GUILD_ID=你的服务器ID

# 验证通过后给的身份组（二选一，优先用 ID）
VERIFIED_ROLE_ID=身份组ID
# VERIFIED_ROLE_NAME=Lumi

# 答错后冷却（分钟）
COOLDOWN_MINUTES=10

# 可选：#公告 频道 ID，用于验证面板里 @ 频道
# ANNOUNCE_CHANNEL_ID=频道ID
